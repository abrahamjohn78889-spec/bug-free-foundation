# ============================================================
# .env.template
#
# HOW TO USE:
#   1. Rename this file to  .env  in the project root
#   2. Fill in your credentials (see comments for each field)
#   3. Run:  node scripts/derive-clob-credentials.mjs
#      to generate CLOB_API_KEY, CLOB_SECRET, CLOB_PASS_PHRASE
#
# This file ships blank — no secrets. Your filled-in .env is
# gitignored and never uploaded anywhere.
# ============================================================

# ---- Mode: PAPER_V1 (safe simulation) or LIVE_V2 (real capital) ----
ENVIRONMENT=PAPER_V1

# ---- Paper simulation ----
PAPER_STARTING_BALANCE=100

# ---- Live wallet (required for LIVE_V2 and for the derive script) ----
WALLET_PRIVATE_KEY=
FUNDER_ADDRESS=

# ---- CLOB API credentials ----
# Leave blank, then run:  node scripts/derive-clob-credentials.mjs
# The script will print the three values below — paste them in.
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASS_PHRASE=
SIGNATURE_TYPE=1

# ---- Endpoints (pre-filled, do not change unless Polymarket migrates) ----
CLOB_HTTP_HOST=https://clob.polymarket.com
CLOB_WS_HOST=wss://ws-subscriptions-clob.polymarket.com/ws
GAMMA_HTTP_HOST=https://gamma-api.polymarket.com
DATA_API_HOST=https://data-api.polymarket.com
CHAIN_ID=137
EXCHANGE_CONTRACT=0x4bFb41d5B3570DeFd03C39a9A4D8dE6Bd8B8982E

# ---- BTC reference price (Chainlink on-chain, no key needed) ----
BTC_REFERENCE_SOURCE=chainlink-onchain
CHAINLINK_RPC_URL=https://polygon-bor-rpc.publicnode.com,https://polygon.drpc.org,https://1rpc.io/matic
CHAINLINK_BTC_USD_FEED=0xc907E116054Ad103354f2D350FD2514433D57F6f
CHAINLINK_DATASTREAMS_API_KEY=
CHAINLINK_DATASTREAMS_API_SECRET=

# ---- Telegram bot (optional, LIVE_V2 only) ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Storage ----
DB_PATH=data/edge5.db
