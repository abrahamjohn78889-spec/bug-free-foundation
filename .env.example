# ============================================================
# Environment Vault (copy to .env and fill in)
# NEVER commit the real .env file. It is gitignored.
#
# Variable names below are the CANONICAL names read by
# lib/*/engine/config.ts. Legacy POLY_* aliases still work as
# fallbacks (noted per line) so older vaults keep functioning.
# ============================================================

# Pipeline selector: PAPER_V1 (safe, simulated, default) or LIVE_V2 (real capital)
# NOTE: the two stacks are fully independent — /v1 is pinned to PAPER_V1 and
# /v2 to LIVE_V2 — so this only affects tooling that reads the default.
ENVIRONMENT=PAPER_V1

# ---- Paper testing ----
PAPER_STARTING_BALANCE=100

# ---- Live V2 credentials (only read when the engine runs in LIVE_V2) ----
# Level 1 signing wallet private key (EIP-712 order signing via the official
# @polymarket/clob-client-v2 SDK). Legacy fallback: POLY_PRIVATE_KEY
WALLET_PRIVATE_KEY=
# Proxy/funder wallet address that holds USDC collateral. Legacy: POLY_PROXY_ADDRESS
FUNDER_ADDRESS=
# Level 2 API credentials, derived once from the signing wallet by the SDK.
# Legacy fallbacks: POLY_API_KEY / POLY_API_SECRET / POLY_API_PASSPHRASE
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASS_PHRASE=
# Polymarket signature type: 0=EOA, 1=POLY_PROXY, 2=POLY_GNOSIS_SAFE.
# Default 1 (proxy) matches the FUNDER_ADDRESS flow; use 0 for a raw EOA wallet.
SIGNATURE_TYPE=1

# ---- Endpoints (defaults track CLOB V2; override only if Polymarket migrates) ----
# CLOB_HTTP_HOST legacy fallback: POLYMARKET_CLOB_URL
CLOB_HTTP_HOST=https://clob.polymarket.com
CLOB_WS_HOST=wss://ws-subscriptions-clob.polymarket.com/ws
GAMMA_HTTP_HOST=https://gamma-api.polymarket.com
# Official public Polymarket Data API — positions, portfolio value, and PnL,
# keyed by wallet address (no auth). Used only for the read-only account mirror.
DATA_API_HOST=https://data-api.polymarket.com
# CHAIN_ID legacy fallback: POLYMARKET_CHAIN_ID (137 = Polygon mainnet)
CHAIN_ID=137
EXCHANGE_CONTRACT=0x4bFb41d5B3570DeFd03C39a9A4D8dE6Bd8B8982E

# ---- BTC reference price feed (DISPLAY ONLY) ----
# Sourced from Chainlink and shown separately from Polymarket contract prices.
# It never derives UP/DOWN contract values and the Standing Limit Order never
# depends on it. (An optional strategy edge can consume it, but no edge is
# active by default.)
#   chainlink-onchain     — reads the on-chain Chainlink BTC/USD aggregator via
#                           a public RPC (default, no credentials).
#   chainlink-datastreams — future low-latency Data Streams API (needs keys).
BTC_REFERENCE_SOURCE=chainlink-onchain
# Comma-separated public Polygon RPC endpoints; the feed rotates on failure.
CHAINLINK_RPC_URL=https://polygon-bor-rpc.publicnode.com,https://polygon.drpc.org,https://1rpc.io/matic
# Chainlink BTC/USD aggregator (Polygon mainnet).
CHAINLINK_BTC_USD_FEED=0xc907E116054Ad103354f2D350FD2514433D57F6f
# Reserved for the future Data Streams swap (unused until credentials exist).
CHAINLINK_DATASTREAMS_API_KEY=
CHAINLINK_DATASTREAMS_API_SECRET=

# ---- Remote dashboard authentication (REQUIRED for remote access) ----
# Operator username for the dashboard login. Optional — defaults to "admin"
# when unset. Changing it invalidates all existing sessions after restart.
DASHBOARD_USERNAME=
# Password for the /v2 dashboard login. Sessions are HMAC-signed with a key
# derived from username+password; changing EITHER invalidates all existing
# sessions after restart. Never stored anywhere except this file.
DASHBOARD_PASSWORD=
# Optional bearer token for headless API control (curl/scripts) without a
# browser session. Leave empty to disable token auth entirely.
BOT_CONTROL_TOKEN=

# ---- Telegram control bot (optional; owned exclusively by the V2 stack) ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Storage ----
DB_PATH=data/edge5.db

# ============================================================
# INC-004 PR-003 — production hardening additions
# ============================================================

# H6 — Server-side session invalidation. Seed for the session HMAC epoch;
# increment (or POST /api/auth/logout-all with BOT_CONTROL_TOKEN) to invalidate
# every outstanding dashboard cookie without rotating DASHBOARD_PASSWORD.
# Runtime state is persisted to data/.session-epoch so restarts don't undo it.
SESSION_EPOCH=0

# H4 — Rate limiter kill switch. Set to "1" only for one-off debugging on a
# firewalled host; production must leave it unset. Never enable in a
# public-facing deployment.
# RATE_LIMIT_DISABLED=0

# INC-004 Stage 5 (kept off by default — flip after full soak on your VPS).
# When 1: reconciler recovers AMBIGUOUS intents (PR-002 C1) and untracked
# exchange orders are auto-cancelled after N consecutive cycles.
# INC_004_INTENT_FIRST=0
# INC_004_UNTRACKED_REMEDIATION=3
